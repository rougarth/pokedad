  PURCHASE_MARKED_BOUGHT
  PURCHASE_MARKED_SKIPPED
  PURCHASE_SNOOZED
  PURCHASE_UNSNOOZED
  PURCHASE_NOTE_UPDATED
  PURCHASE_CHECKLIST_VIEWED
  PURCHASE_DECISION_CHANGED
  WISHLIST_ITEM_CREATED
  WISHLIST_ITEM_UPDATED
  WISHLIST_ITEM_DELETED
  WISHLIST_ITEM_ENABLED
  WISHLIST_ITEM_DISABLED
  WISHLIST_MATCH_PREVIEW_RUN
  WISHLIST_PRODUCT_MATCHED
  WISHLIST_PRODUCT_IGNORED
  WISHLIST_ALERT_PRIORITY_SET
  STORE_SAFETY_MATRIX_VIEWED
  STORE_SAFETY_DETAIL_VIEWED
  STORE_SAFETY_ITEM_UPDATED
  BLOCKED_STORE_ADAPTER_ATTEMPTED
  RESEARCH_ONLY_STORE_SELECTED_IN_WISHLIST
  MANUAL_STORE_LINK_CREATED
  MANUAL_STORE_LINK_UPDATED
  MANUAL_STORE_LINK_DELETED
  MANUAL_STORE_LINK_ENABLED
  MANUAL_STORE_LINK_DISABLED
  MANUAL_STORE_LINK_OPENED
  MANUAL_STORE_LINK_ATTACHED_TO_WISHLIST
  RELEASE_CALENDAR_ITEM_CREATED
  RELEASE_CALENDAR_ITEM_UPDATED
  RELEASE_CALENDAR_ITEM_DELETED
  RELEASE_CALENDAR_ITEM_ENABLED
  RELEASE_CALENDAR_ITEM_DISABLED
  RELEASE_CALENDAR_MARKED_RELEASED
  RELEASE_CALENDAR_MARKED_BOUGHT
  RELEASE_CALENDAR_MARKED_SKIPPED
  RELEASE_REMINDER_TEST_SENT
  RELEASE_REMINDER_DELIVERY_FAILED
