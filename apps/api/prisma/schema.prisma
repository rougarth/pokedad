  CART_QUEUE_RETRY_REQUESTED
  ALERT_TEST_SENT
  ADAPTER_STATUS_CHECKED
  ADAPTER_TEST_SEARCH_RUN
  ADAPTER_LOOKUP_RUN
  BEST_BUY_SCAN_RUN
  ADAPTER_MISSING_API_KEY
  ADAPTER_ERROR
  BEST_BUY_SCAN_STARTED
  BEST_BUY_SCAN_SUCCEEDED
  BEST_BUY_SCAN_FAILED
  BEST_BUY_SCAN_API_KEY_MISSING
  BEST_BUY_SCAN_RATE_LIMITED
  BEST_BUY_SCAN_ENABLED
  BEST_BUY_SCAN_DISABLED
  BEST_BUY_RESULT_ACCEPTED
  BEST_BUY_RESULT_OVER_LIMIT
  BEST_BUY_ALERT_CREATED
  BEST_BUY_DUPLICATE_ALERT_SUPPRESSED
  MSRP_MAPPING_CANDIDATE_CREATED
  MSRP_SUGGESTION_GENERATED
  MSRP_MAPPING_ACCEPTED
  MSRP_MAPPING_CHANGED
  MSRP_MAPPING_IGNORED
  MSRP_MAPPING_MARKED_NEEDS_REVIEW
  MSRP_PRICE_RECALCULATED
  MSRP_MAPPING_ALERT_CREATED
  MSRP_MAPPING_DUPLICATE_ALERT_SUPPRESSED
  ALERT_CHANNEL_CREATED
  ALERT_CHANNEL_DELETED
  ALERT_CHANNEL_ENABLED
  ALERT_CHANNEL_DISABLED
  ALERT_CHANNEL_TEST_FAILED
  ALERT_EVENT_DELIVERED
  ALERT_DELIVERY_FAILED
  ALERT_DELIVERY_SUPPRESSED
  ALERT_SECRET_STORED_ENCRYPTED
  DISCORD_OAUTH_STARTED
  DISCORD_OAUTH_CALLBACK_SUCCEEDED
