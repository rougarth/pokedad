generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreSessionState {
  LOGGED_IN
  NOT_LOGGED_IN
  LOGIN_EXPIRED
  HUMAN_CHECK_NEEDED
  QUEUE_OR_WAITING_ROOM
  QUEUE_DETECTED
  CAPTCHA_DETECTED
  UNKNOWN
}

enum ProductCategoryKind {
  ELITE_TRAINER_BOX
  POKEMON_CENTER_ETB
  BOOSTER_BUNDLE
  BOOSTER_BOX
  COLLECTION_BOX
  PREMIUM_COLLECTION
  ULTRA_PREMIUM_COLLECTION
  MINI_TIN
  TIN
  SLEEVED_BOOSTER
  NEW_RELEASE
}

enum SellerPolicy {
  OFFICIAL_ONLY
  APPROVED_SELLERS_ONLY
  MANUAL_REVIEW
}

enum FulfillmentPreference {
  SHIPPING
  PICKUP
  EITHER
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  PREORDER
  BACKORDER
  UNKNOWN
}

enum CartAssistStatus {
  NOT_ATTEMPTED
  PRODUCT_FOUND
  PRICE_ACCEPTED
  ADD_TO_CART_ATTEMPTED
  CART_READY
  LOGIN_REQUIRED
  HUMAN_CHECK_REQUIRED
  QUEUE_DETECTED
  CAPTCHA_DETECTED
  SOLD_OUT
  PRICE_CHANGED
  FAILED
  SKIPPED
}

enum CartAssistMode {
  OPEN_ONLY
  LOCAL_HELPER_READY
  DISABLED
}

enum PriceStatus {
  ACCEPTED
  MSRP_MATCH
  ACCEPTED_MARKUP
  OVER_LIMIT
  THIRD_PARTY_SKIPPED
  UNKNOWN_MSRP
}

enum AlertChannelType {
  TELEGRAM
  DISCORD_WEBHOOK
  SMS
  EMAIL
  BROWSER
}

enum AlertEventType {
  MSRP_FOUND
  ACCEPTABLE_PRICE_FOUND
  CART_READY
  HUMAN_ACTION_NEEDED
  LOGIN_EXPIRED
  PRICE_CHANGED
  SOLD_OUT
  ERROR
  RELEASE_REMINDER
}

enum AlertEventStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
}

enum AlertDeliveryStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
  CHANNEL_DISABLED
  CONFIGURATION_NEEDED
}

enum AlertPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum WishlistPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  IGNORE
}

enum WishlistAlertBehavior {
  ALERT_IMMEDIATELY
  DASHBOARD_ONLY
  DO_NOT_ALERT
  REVIEW_FIRST
}

enum ManualStoreLinkType {
  PRODUCT
  SEARCH
  CATEGORY
  RELEASE_PAGE
  STORE_HOME
  CUSTOM
}

enum AlertTemplateType {
  ACCEPTED_PRICE_FOUND
  MSRP_MATCH_FOUND
  PRICE_DROPPED_ACCEPTED
  UNKNOWN_MSRP_MAPPING
  HUMAN_REVIEW_NEEDED
  SCAN_FAILED
  CONFIGURATION_NEEDED
  TEST_ALERT
  RELEASE_REMINDER
  TEST_RELEASE_REMINDER
}

enum ReleaseCalendarStatus {
  PLANNED
  UPCOMING
  RELEASED
  WATCHING
  BOUGHT
  SKIPPED
  CANCELED
}

enum ReleaseReminderOffset {
  SEVEN_DAYS
  THREE_DAYS
  ONE_DAY
  TWELVE_HOURS
  ONE_HOUR
  AT_RELEASE
}

enum TodayActionStatus {
  OPEN
  IN_PROGRESS
  DONE
  SNOOZED
  DISMISSED
}

enum PurchaseDecisionStatus {
  NEW
  OPENED
  BOUGHT
  SKIPPED
  SNOOZED
  SOLD_OUT
  TOO_EXPENSIVE
  NOT_INTERESTED
  NEEDS_MAPPING
}

enum PurchaseSkipReason {
  PRICE_TOO_HIGH
  SOLD_OUT
  NOT_INTERESTED
  WRONG_PRODUCT
  ALREADY_BOUGHT
  NEEDS_REVIEW
  OTHER
}

enum LiveAlertStatus {
  NOT_SENT
  READY
  SENT
  FAILED
  SUPPRESSED
}

