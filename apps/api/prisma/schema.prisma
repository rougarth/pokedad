  TODAY_PURCHASE_DECISION_MADE
  TODAY_RELEASE_ACTION_TAKEN
  TODAY_MSRP_MAPPING_OPENED
  ANALYTICS_DASHBOARD_VIEWED
  ANALYTICS_FILTER_CHANGED
  ANALYTICS_EXPORT_DOWNLOADED
  ANALYTICS_DETAIL_OPENED
  HELPER_CONNECTED
  DATA_EXPORTED
  DATA_DELETED
}

enum MSRPMappingStatus {
  UNMAPPED
  SUGGESTED
  MAPPED
  IGNORED
  NEEDS_REVIEW
}

enum MSRPMappingConfidence {
  LOW
  MEDIUM
  HIGH
  MANUAL
}

enum SkipReason {
  NONE
  THIRD_PARTY_SELLER
  MARKETPLACE_SCALPER
  USED_OR_OPEN_BOX
  SINGLES_OR_LOOSE_CARDS
  PRICE_ABOVE_MAX
  SUSPICIOUS_LISTING
  HUMAN_CHECK_REQUIRED
  QUEUE_DETECTED
  PURCHASE_LIMIT_MANUAL_DECISION
  STORE_DISABLED
}

enum PriceRuleScope {
  GLOBAL
  STORE
  CATEGORY
  PRODUCT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stores            Store[]
  productMsrps      ProductMSRP[]
  watchRules        ProductWatchRule[]
  priceRules        PriceRule[]
  alertChannels     AlertChannel[]
  alertEvents       AlertEvent[]
  auditLogs         AuditLog[]          @relation("AuditActor")
  appSettings       AppSetting[]
    encryptedSecrets  EncryptedSecret[]
    msrpMappings      ProductMSRPMapping[]
    purchaseDecisions PurchaseDecision[]
    wishlistItems     WishlistItem[]
    manualStoreLinks  ManualStoreLink[]
    releaseCalendarItems ReleaseCalendarItem[]
    actionItemStates ActionItemState[]
  }

model Store {
  id                    String            @id @default(cuid())
  ownerId               String
  name                  String
  slug                  String
  baseUrl               String
  loginUrl              String?
  cartUrl               String?
  monitoringEnabled     Boolean           @default(false)
  cartAssistEnabled     Boolean           @default(false)
  cartAssistMode        CartAssistMode    @default(OPEN_ONLY)
  sellerPolicy          SellerPolicy      @default(OFFICIAL_ONLY)
  defaultToleranceCents Int?
  adapterSafetyLevel    String            @default("OPEN_ONLY")
  lastSuccessfulCheckAt DateTime?
  lastError             String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  owner          User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sessionStatus  StoreSessionStatus?
  retailerProducts RetailerProduct[]
  stockChecks    StockCheckResult[]
  priceRules     PriceRule[]

  @@unique([ownerId, slug])
  @@index([ownerId, monitoringEnabled])
}

model StoreSessionStatus {
  id            String            @id @default(cuid())
  storeId       String            @unique
  state         StoreSessionState @default(UNKNOWN)
  checkedAt     DateTime?
  message       String?
  helperId      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model ProductCategory {
  id          String              @id @default(cuid())
  kind        ProductCategoryKind @unique
  label       String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  msrps            ProductMSRP[]
  watchRules       ProductWatchRule[]
  retailerProducts RetailerProduct[]
    priceRules       PriceRule[]
    suggestedMappings ProductMSRPMapping[] @relation("SuggestedCategory")
    mappedMappings    ProductMSRPMapping[] @relation("MappedCategory")
    wishlistItems     WishlistItem[]
    manualStoreLinks  ManualStoreLink[]
    releaseCalendarItems ReleaseCalendarItem[]
  }

  model WishlistItem {
    id                String                @id @default(cuid())
    ownerId           String
    name              String
    setName           String?
    categoryId        String?
    storeKey          String?
    priority          WishlistPriority      @default(NORMAL)
    alertBehavior     WishlistAlertBehavior @default(ALERT_IMMEDIATELY)
    desiredQuantity   Int?
    maxPriceCents     Int?
    allowedMarkupCents Int?
    keywords          String[]
    isActive          Boolean               @default(true)
    notes             String?
    createdAt         DateTime              @default(now())
    updatedAt         DateTime              @updatedAt

    owner    User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    category ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
    manualStoreLinks ManualStoreLink[]
    releaseCalendarItems ReleaseCalendarItem[]

    @@index([ownerId, isActive])
    @@index([ownerId, priority])
    @@index([categoryId])
  }

  model ManualStoreLink {
    id             String              @id @default(cuid())
    ownerId        String
    storeKey       String
    storeDisplayName String
    title          String
    url            String
    linkType       ManualStoreLinkType @default(SEARCH)
    priority       WishlistPriority    @default(NORMAL)
    wishlistItemId String?
    setName        String?
    categoryId     String?
    notes          String?
    isActive       Boolean             @default(true)
    lastOpenedAt   DateTime?
    openCount      Int                 @default(0)
    createdAt      DateTime            @default(now())
    updatedAt      DateTime            @updatedAt

    owner        User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
    wishlistItem WishlistItem?     @relation(fields: [wishlistItemId], references: [id], onDelete: SetNull)
    category     ProductCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
    releaseLinks ReleaseCalendarManualStoreLink[]

    @@index([ownerId, isActive])
    @@index([ownerId, storeKey])
    @@index([wishlistItemId])
    @@index([categoryId])
  }

model ReleaseCalendarItem {
  id              String                 @id @default(cuid())
  ownerId         String
  title           String
  setName         String?
  productName     String?
  categoryId      String?
  releaseDate     DateTime
  timezone        String?
  priority        AlertPriority          @default(NORMAL)
  status          ReleaseCalendarStatus  @default(UPCOMING)
  wishlistItemId  String?
  notes           String?
  isActive        Boolean                @default(true)
  discordReminder Boolean                @default(true)
  reminderOffsets ReleaseReminderOffset[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  owner         User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  category      ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  wishlistItem  WishlistItem?    @relation(fields: [wishlistItemId], references: [id], onDelete: SetNull)
  manualLinks   ReleaseCalendarManualStoreLink[]

  @@index([ownerId, isActive])
  @@index([ownerId, status])
  @@index([releaseDate])
  @@index([wishlistItemId])
  @@index([categoryId])
}

model ReleaseCalendarManualStoreLink {
  id                    String   @id @default(cuid())
  releaseCalendarItemId String
  manualStoreLinkId     String
  createdAt             DateTime @default(now())

  releaseCalendarItem ReleaseCalendarItem @relation(fields: [releaseCalendarItemId], references: [id], onDelete: Cascade)
  manualStoreLink     ManualStoreLink     @relation(fields: [manualStoreLinkId], references: [id], onDelete: Cascade)

  @@unique([releaseCalendarItemId, manualStoreLinkId])
  @@index([manualStoreLinkId])
}

model ActionItemState {
  id           String            @id @default(cuid())
  userId       String
  itemKey      String
  status       TodayActionStatus @default(OPEN)
  snoozedUntil DateTime?
  dismissedAt  DateTime?
  doneAt       DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemKey])
  @@index([userId, status])
  @@index([snoozedUntil])
}

model ProductMSRP {
  id                 String   @id @default(cuid())
  ownerId            String?
  categoryId         String?
  owner              User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  productNamePattern String?
  msrpCents          Int
  currency           String   @default("USD")
  effectiveFrom      DateTime @default(now())
  effectiveTo        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  category ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([categoryId])
}

model ProductWatchRule {
  id                   String                @id @default(cuid())
  ownerId              String
  name                 String
  monitorAllSealed     Boolean               @default(true)
  categoryId           String?
  monitorNewReleases   Boolean               @default(true)
  ignoreSingles        Boolean               @default(true)
  ignoreThirdParty     Boolean               @default(true)
  fulfillmentPreference FulfillmentPreference @default(EITHER)
  pickupZip            String?
  pickupRadiusMiles    Int?
  quantityWanted       Int                   @default(1)
  maxQuantityPerStoreProduct Int             @default(1)
  enabled              Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  owner    User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  category ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([ownerId, enabled])
}

model PriceRule {
  id                  String         @id @default(cuid())
  ownerId             String
  scope               PriceRuleScope
  label               String         @default("Price rule")
  target              String         @default("All sealed products")
  storeId             String?
  categoryId          String?
  retailerProductId   String?
  msrpCents           Int?
  allowedMarkupCents  Int            @default(0)
  toleranceCents      Int?
  customMaxPriceCents Int?
  alertThresholdCents Int?
  storeSpecificToleranceCents    Int?
  categorySpecificToleranceCents Int?
  productSpecificOverrideCents   Int?
  enabled             Boolean        @default(true)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  store           Store?           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category        ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  retailerProduct RetailerProduct? @relation(fields: [retailerProductId], references: [id], onDelete: Cascade)

  @@index([ownerId, scope, enabled])
}

model RetailerProduct {
  id                 String   @id @default(cuid())
  storeId            String
  categoryId         String?
  externalId         String?
  productUrl         String
  imageUrl           String?
  name               String
  sellerName         String?
  sellerIsOfficial   Boolean  @default(false)
  marketplaceListing Boolean  @default(false)
  suspicious         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  store       Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category    ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stockChecks StockCheckResult[]
  priceRules  PriceRule[]
  msrpMappings ProductMSRPMapping[]

  @@unique([storeId, externalId])
  @@index([storeId])
  @@index([productUrl])
}

model ProductMSRPMapping {
  id                  String                @id @default(cuid())
  ownerId             String
  storeKey            String
  retailerSku         String?
  retailerProductId   String?
  productName         String
  normalizedProductKey String
  productUrl          String?
  imageUrl            String?
  currentPriceCents   Int?
  detectedKeywords    String[]
  suggestedCategoryId String?
  mappedCategoryId    String?
  msrpCents           Int?
  acceptedMaxPriceCents Int?
  confidence          MSRPMappingConfidence @default(LOW)
  status              MSRPMappingStatus     @default(UNMAPPED)
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  owner             User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  retailerProduct   RetailerProduct? @relation(fields: [retailerProductId], references: [id], onDelete: SetNull)
  suggestedCategory ProductCategory?  @relation("SuggestedCategory", fields: [suggestedCategoryId], references: [id], onDelete: SetNull)
  mappedCategory    ProductCategory?  @relation("MappedCategory", fields: [mappedCategoryId], references: [id], onDelete: SetNull)

  @@unique([ownerId, storeKey, retailerSku])
  @@unique([ownerId, storeKey, normalizedProductKey])
  @@index([ownerId, status])
  @@index([storeKey, retailerSku])
}

model StockCheckResult {
  id                    String      @id @default(cuid())
  storeId               String
  retailerProductId     String
  checkedAt             DateTime    @default(now())
  priceCents            Int?
  msrpCents             Int?
  acceptedMaxPriceCents Int?
  accepted              Boolean     @default(false)
  sellerName            String?
  sellerAccepted        Boolean     @default(false)
  priceStatus           PriceStatus @default(UNKNOWN_MSRP)
  alertStatus           LiveAlertStatus @default(NOT_SENT)
  stockStatus           StockStatus @default(UNKNOWN)
  shippingAvailable     Boolean?
  pickupAvailable       Boolean?
  skipReason            SkipReason  @default(NONE)
  ignored               Boolean     @default(false)
  bought                Boolean     @default(false)
  snoozedUntil          DateTime?
  rawMetadata           Json?

  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  retailerProduct RetailerProduct @relation(fields: [retailerProductId], references: [id], onDelete: Cascade)
  cartAttempts    CartAssistAttempt[]
  alertEvents     AlertEvent[]
  purchaseDecision PurchaseDecision?

  @@index([checkedAt])
  @@index([storeId, stockStatus, accepted])
}

model PurchaseDecision {
  id                 String                 @id @default(cuid())
  ownerId            String
  stockCheckResultId String                 @unique
  status             PurchaseDecisionStatus @default(NEW)
  skipReason         PurchaseSkipReason?
  note               String?
  quantity           Int?
  finalPriceCents    Int?
  openedAt           DateTime?
  boughtAt           DateTime?
  skippedAt          DateTime?
  snoozedUntil       DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  owner            User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  stockCheckResult StockCheckResult @relation(fields: [stockCheckResultId], references: [id], onDelete: Cascade)

  @@index([ownerId, status])
  @@index([snoozedUntil])
}

model CartAssistAttempt {
  id                   String           @id @default(cuid())
  stockCheckResultId   String
  status               CartAssistStatus @default(NOT_ATTEMPTED)
  requestedQuantity    Int              @default(1)
  productUrl           String
  cartUrl              String?
  helperId             String?
  stopReason           String?
  lastMessage          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  stockCheckResult StockCheckResult @relation(fields: [stockCheckResultId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
}

model AlertChannel {
  id                String           @id @default(cuid())
  ownerId           String
  type              AlertChannelType
  label             String
  enabled           Boolean          @default(false)
  encryptedSecretId String?
  destinationHint   String?
  lastTestStatus    AlertDeliveryStatus?
  lastTestAt        DateTime?
  lastError         String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  encryptedSecret EncryptedSecret? @relation(fields: [encryptedSecretId], references: [id], onDelete: SetNull)
  events          AlertEvent[]
  deliveries      AlertDelivery[]

  @@index([ownerId, type, enabled])
}

model AlertEvent {
  id                 String           @id @default(cuid())
  ownerId            String?
  alertChannelId     String?
  stockCheckResultId String?
  type               AlertEventType
  templateType       AlertTemplateType?
  title              String           @default("PokeDad Radar Alert")
  priority           AlertPriority     @default(NORMAL)
  status             AlertEventStatus @default(PENDING)
  message            String
  error              String?
  createdAt          DateTime         @default(now())
  sentAt             DateTime?

  alertChannel     AlertChannel?     @relation(fields: [alertChannelId], references: [id], onDelete: SetNull)
  owner            User?             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  stockCheckResult StockCheckResult? @relation(fields: [stockCheckResultId], references: [id], onDelete: SetNull)
  deliveries      AlertDelivery[]

  @@index([createdAt])
  @@index([status, type])
  @@index([ownerId, createdAt])
}

model AlertDelivery {
  id             String              @id @default(cuid())
  alertEventId   String
  alertChannelId String
  provider       AlertChannelType
  status         AlertDeliveryStatus @default(PENDING)
  errorSummary   String?
  retryCount     Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  sentAt         DateTime?

  alertEvent   AlertEvent   @relation(fields: [alertEventId], references: [id], onDelete: Cascade)
  alertChannel AlertChannel @relation(fields: [alertChannelId], references: [id], onDelete: Cascade)

  @@index([alertEventId, status])
  @@index([alertChannelId, createdAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  actorUserId String?
  action      AuditAction
  summary     String
  metadata    Json?
  ipHash      String?
  createdAt   DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorUserId, action])
}

model AppSetting {
  id        String   @id @default(cuid())
  ownerId   String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, key])
}

model EncryptedSecret {
  id           String   @id @default(cuid())
  ownerId      String
  name         String
  keyVersion   String
  ivBase64     String
  authTagBase64 String
  cipherTextBase64 String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  alertChannels AlertChannel[]

  @@unique([ownerId, name])
}
