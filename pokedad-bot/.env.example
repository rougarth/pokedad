REDIS_URL="redis://localhost:6379"
API_BASE_URL="http://127.0.0.1:4000"
BOT_PORT=3456
WORKER_ID="safe-worker-1"

# The bot never receives retailer credentials, cookies, payment data, or webhooks.
BEST_BUY_API_KEY_CONFIGURED=false
# Set the matching compose variable instead of sharing the key with this worker.
BOT_BEST_BUY_API_KEY_CONFIGURED=false

# Optional Webshare egress pool for explicitly approved API traffic only.
# File format: host:port:username:password, one proxy per line.
OUTBOUND_PROXY_ENABLED=false
OUTBOUND_PROXY_FILE="./proxies.txt"
