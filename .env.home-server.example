# Copy to .env.home-server on the home server. Never commit the real file.
NODE_ENV=production
POSTGRES_DB="pokedad"
POSTGRES_USER="pokedad"
POSTGRES_PASSWORD="CHANGE_ME_STRONG_DATABASE_PASSWORD"
DATABASE_URL="postgresql://pokedad:CHANGE_ME_STRONG_DATABASE_PASSWORD@postgres:5432/pokedad?schema=public"
REDIS_URL="redis://redis:6379"
SESSION_SECRET="CHANGE_ME_LONG_RANDOM_SESSION_SECRET"
# Exactly 32 characters. Keep stable and back it up securely.
ENCRYPTION_KEY="CHANGE_ME_32_BYTE_STABLE_KEY__"
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
API_HOST=0.0.0.0
API_PORT=4000
PUBLIC_APP_URL="https://pokedad.example.com"
WEB_ORIGIN="https://pokedad.example.com"
API_BASE_URL="https://pokedad.example.com/api"
VITE_API_BASE_URL="/api"
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="https://pokedad.example.com/api/discord/oauth/callback"
BEST_BUY_API_KEY=""
HELPER_SHARED_TOKEN=""
CLOUDFLARE_TUNNEL_TOKEN=""
